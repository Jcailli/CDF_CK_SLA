<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Coupe de France – Classement{% endblock %}</title>
    <style>
        :root { --bg: #0f172a; --card: #1e293b; --text: #e2e8f0; --accent: #38bdf8; --muted: #94a3b8; }
        * { box-sizing: border-box; }
        body { font-family: system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 1rem; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .container { width: min(100%, 960px); margin: auto; }
        h1 { font-size: 1.5rem; margin-bottom: 0.5rem; color: var(--accent); }
        .sub { color: var(--muted); font-size: 0.9rem; margin-bottom: 1.5rem; }
        form { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
        label { color: var(--muted); }
        select, button { padding: 0.5rem 0.75rem; border-radius: 6px; border: 1px solid #334155; background: var(--card); color: var(--text); font-size: 1rem; }
        button { cursor: pointer; background: var(--accent); color: var(--bg); border: none; font-weight: 600; }
        button:hover { filter: brightness(1.1); }
        .card { background: var(--card); border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 1rem; }
        .card h2 { font-size: 1rem; margin: 0 0 0.75rem 0; color: var(--muted); }
        .compet-list { list-style: none; padding: 0; margin: 0; font-size: 0.9rem; }
        .compet-list li { padding: 0.25rem 0; border-bottom: 1px solid #334155; }
        .compet-list li:last-child { border-bottom: none; }
        .finale { color: var(--accent); }
        table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
        .table-classement-general { width: auto; margin: 0 auto; }
        th, td { text-align: left; padding: 0.6rem 0.75rem; border-bottom: 1px solid #334155; }
        th { color: var(--muted); font-weight: 600; }
        tr:hover { background: rgba(56, 189, 248, 0.06); }
        .r { text-align: right; }
        .points { font-weight: 600; color: var(--accent); min-width: 88px; }
        .table-classement-general .col-cat { min-width: 74px; }
        /* Manches retenues pour le total (4 meilleures N2/N3, 6 meilleures N1) */
        .table-classement-general td.slot-best {
            background: #14532d;
            color: #ecfdf5;
            font-weight: 600;
        }
        .table-classement-general tr:hover td.slot-best {
            background: #166534;
            color: #ecfdf5;
        }
        .n3-qualif-legend { font-size: 0.82rem; margin: 0 0 0.5rem 0; max-width: 52rem; }
        /* Qualifiés finale N3 : ambre (distinct du vert = manches retenues dans le total) */
        .table-classement-general tr.row-n3-qualifie td {
            background: rgba(245, 158, 11, 0.22);
        }
        .table-classement-general tr.row-n3-qualifie td.slot-best {
            background: #14532d !important;
            color: #ecfdf5 !important;
            box-shadow: inset 0 0 0 2px #f59e0b;
        }
        .table-classement-general tr.row-n3-qualifie:hover td {
            background: rgba(245, 158, 11, 0.32);
        }
        .table-classement-general tr.row-n3-qualifie:hover td.slot-best {
            background: #166534 !important;
            color: #ecfdf5 !important;
            box-shadow: inset 0 0 0 2px #fbbf24;
        }
        .erreur { color: #f87171; padding: 1rem; }
        .manche-title, .embarcation-title { font-size: 0.95rem; margin: 1.25rem 0 0.5rem 0; color: var(--text); }
        .tabs-header { display: flex; flex-wrap: wrap; gap: 0; border-bottom: 1px solid #334155; margin-bottom: 1rem; }
        .tabs-header .tab-btn { padding: 0.6rem 1rem; border: none; background: transparent; color: var(--muted); cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; font-size: 0.95rem; }
        .tabs-header .tab-btn:hover { color: var(--text); }
        .tabs-header .tab-btn.active { color: var(--accent); font-weight: 600; border-bottom-color: var(--accent); }
        .tab-panel { display: none; }
        .tab-panel.active { display: block; }
        a { color: var(--accent); }
        .export-buttons { margin: 0.5rem 0 1rem 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
        .btn { display: inline-block; padding: 0.5rem 0.75rem; border-radius: 6px; background: var(--accent); color: var(--bg); text-decoration: none; font-weight: 600; font-size: 0.9rem; border: none; }
        .btn:hover { filter: brightness(1.1); }
        .btn-sm { padding: 0.4rem 0.6rem; font-size: 0.85rem; }
    </style>
    {% block styles %}{% endblock %}
</head>
<body>
    <div class="container">
        {% block body %}{% endblock %}
    </div>
    {% block scripts %}{% endblock %}
</body>
</html>
